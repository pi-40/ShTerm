# ==========================================
# 1. ROOT TARGETS (Where your .sln sits)
# ==========================================
/*.suo
/*.user
/*.sln.docstates
/.vs/
/.idea/
/.vscode/

# Root OS files
/.DS_Store
/Thumbs.db

# ==========================================
# 2. SRC TARGETS (Every C# project folder)
# ==========================================
# Exclude compiled output
src/**/[Dd]ebug/
src/**/[Rr]elease/
src/**/bin/
src/**/obj/
src/**/x64/
src/**/x86/

# Exclude project-level user settings
src/**/*.user
src/**/*.userosscache

# Exclude NuGet package leftovers
src/**/packages/
!src/**/packages/repositories.config
